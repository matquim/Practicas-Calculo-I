import sympy as sp
import matplotlib.pyplot as plt
import numpy as np

x = sp.symbols('x')

f = sp.sin(x)

taylor_1 = f.series(x, 0, 1).removeO()
taylor_3 = f.series(x, 0, 3).removeO()
taylor_5 = f.series(x, 0, 5).removeO()

f_lambdified = sp.lambdify(x, f, 'numpy')
taylor_1_lambdified = sp.lambdify(x, taylor_1, 'numpy')
taylor_3_lambdified = sp.lambdify(x, taylor_3, 'numpy')
taylor_5_lambdified = sp.lambdify(x, taylor_5, 'numpy')

x_vals = np.linspace(-2*np.pi, 2*np.pi, 100)

y = f_lambdified(x_vals)
y1 = taylor_1_lambdified(x_vals)
y3 = taylor_3_lambdified(x_vals)
y5 = taylor_5_lambdified(x_vals)

plt.plot(x_vals, y, label="sin(x)")
plt.plot(x_vals, y1, "-.", label="Taylor Orden 1")
plt.plot(x_vals, y3, "-.", label="Taylor Orden 3")
plt.plot(x_vals, y5, "-.", label="Taylor Orden 5")

plt.grid()
plt.legend()
plt.axhline(0, color='black', linewidth=0.5)
plt.axvline(0, color='black', linewidth=0.5)
plt.ylim(-2, 2)

plt.show()
